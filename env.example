# 환경 변수 템플릿 — `cp env.example .env.local` 후 값 입력 (구 env.sample 통합본).
#
# ────────────────────────────────────────────────
# AI Provider API Keys  (server-side only)
# ────────────────────────────────────────────────

# Google Gemini  — https://aistudio.google.com/apikey
# Free tier: 1,500 RPD (Flash), great JSON schema support
GEMINI_API_KEY=

# OpenAI  — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Groq  — https://console.groq.com/keys
# Free tier: ~14,400 RPD (llama-3.3-70b), very fast streaming
GROQ_API_KEY=

# Anthropic (Claude)  — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenRouter  — https://openrouter.ai/settings/keys
# Aggregates many providers; has free models
OPENROUTER_API_KEY=

# ────────────────────────────────────────────────
# Main model
# ────────────────────────────────────────────────
# Values: gemini | openai | groq | anthropic | openrouter
# 해당 프로바이더 API 키 + 아래 둘 다 필요 (기본값 주입 없음).
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash

# ────────────────────────────────────────────────
# Fallback model  (used on token-overflow / error)
# ────────────────────────────────────────────────
# Can be a different provider — cross-provider fallback is supported.
FALLBACK_PROVIDER=gemini
FALLBACK_MODEL=gemini-2.5-flash-lite

# ────────────────────────────────────────────────
# Java remote execution  (POST /api/java/execute → upstream)
# ────────────────────────────────────────────────
# Base URL of the Java runner service (no trailing slash required).
JAVA_EXECUTION_SERVICE_URL=

# Optional. Sent as Authorization: Bearer <token> when set.
JAVA_EXECUTION_SERVICE_TOKEN=


# ────────────────────────────────────────────────
# Contact Email (SMTP)
# ────────────────────────────────────────────────
# Email address to receive inquiries (recipient email)
CONTACT_TO_EMAIL=
# Email address to send from (must match SMTP account)
CONTACT_FROM_EMAIL=
# SMTP configuration — Gmail example: host=smtp.gmail.com, port=587, user=account@gmail.com, pass=app-password
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=